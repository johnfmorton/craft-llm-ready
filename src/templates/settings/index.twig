{% import '_includes/forms.twig' as forms %}

{{ forms.lightswitchField({
    label: 'Enabled',
    instructions: 'Whether LLM Ready is globally enabled.',
    id: 'enabled',
    name: 'enabled',
    on: settings.enabled,
}) }}

<hr>

<h2>Detection Methods</h2>

{{ forms.lightswitchField({
    label: 'Content Negotiation',
    instructions: 'Serve Markdown when the request includes an <code>Accept: text/markdown</code> header.',
    id: 'enableContentNegotiation',
    name: 'enableContentNegotiation',
    on: settings.enableContentNegotiation,
}) }}

{{ forms.lightswitchField({
    label: 'AI Bot User-Agent Detection',
    instructions: 'Automatically serve Markdown to known AI crawlers (GPTBot, ClaudeBot, etc.).',
    id: 'enableUserAgentDetection',
    name: 'enableUserAgentDetection',
    on: settings.enableUserAgentDetection,
}) }}

{{ forms.editableTableField({
    label: 'Additional Bot User-Agents',
    instructions: 'Add custom user-agent strings to detect as AI bots.',
    id: 'additionalBotUserAgents',
    name: 'additionalBotUserAgents',
    cols: {
        value: {
            heading: 'User-Agent String',
            type: 'singleline',
        },
    },
    rows: settings.additionalBotUserAgents|map(ua => { value: ua }),
    allowAdd: true,
    allowDelete: true,
    allowReorder: true,
}) }}

<hr>

<h2>Content Extraction</h2>

{{ forms.textField({
    label: 'Content Selector',
    instructions: 'CSS selectors for extracting main content from HTML (comma-separated). Used when no dedicated LLM template is configured.',
    id: 'contentSelector',
    name: 'contentSelector',
    value: settings.contentSelector,
    placeholder: 'main, article, [role="main"], .content, #content',
}) }}

{{ forms.textField({
    label: 'Exclude Selector',
    instructions: 'CSS selectors for elements to strip from the HTML before Markdown conversion (comma-separated). Use this to remove decorative or non-content elements such as carousels, marquees, or anything marked with `[data-nosnippet]`.',
    id: 'excludeSelector',
    name: 'excludeSelector',
    value: settings.excludeSelector,
    placeholder: '.carousel, [data-nosnippet], .decorative',
}) }}

<hr>

<h2>Response Headers</h2>

{{ forms.lightswitchField({
    label: 'X-Robots-Tag: noindex',
    instructions: 'Add a <code>noindex</code> header to Markdown responses to prevent search engines from indexing them.',
    id: 'noindexHeader',
    name: 'noindexHeader',
    on: settings.noindexHeader,
}) }}

{{ forms.lightswitchField({
    label: 'Auto-inject Discovery Tag',
    instructions: 'Automatically add <code>&lt;link rel="alternate" type="text/markdown"&gt;</code> to HTML pages.',
    id: 'autoInjectDiscoveryTag',
    name: 'autoInjectDiscoveryTag',
    on: settings.autoInjectDiscoveryTag,
}) }}

<hr>

<h2>Caching</h2>

{{ forms.textField({
    label: 'Cache TTL (seconds)',
    instructions: 'How long to cache Markdown output. Set to <code>0</code> to disable caching.',
    id: 'cacheTtl',
    name: 'cacheTtl',
    value: settings.cacheTtl,
    type: 'number',
    min: 0,
    size: 10,
}) }}

<hr>

<h2>llms.txt</h2>

{{ forms.textareaField({
    label: 'Site Description',
    instructions: 'Introduction text for the <code>/llms.txt</code> file. Appears as a blockquote below the site name.',
    id: 'llmsTxtIntro',
    name: 'llmsTxtIntro',
    value: settings.llmsTxtIntro,
    rows: 4,
}) }}

{{ forms.textField({
    label: 'Description Field',
    instructions: 'Field handle to use for entry descriptions in <code>/llms.txt</code> and listing pages (e.g., <code>summary</code>, <code>excerpt</code>). Use dot notation to traverse sub-fields and sub-objects (e.g., <code>seo.seoDescription</code> for a ContentBlock sub-field, or <code>seo.description</code> for an Ether SEO field). Append <code>()</code> to call a no-argument method (e.g., <code>myField.getResolvedValue()</code>). Generated Field handles are also supported. For SEOmatic, use the special value <code>seomatic:description</code> to invoke SEOmatic\'s full resolution chain. See <a href="https://github.com/johnfmorton/craft-llm-ready/blob/main/SEO-PLUGINS.md">SEO-PLUGINS.md</a> for SEOmatic, Ether SEO, SEOmate, and SEO Fields recipes. Leave blank to auto-extract from the first text field. When set, the configured field is authoritative — no fallback is attempted if it resolves to nothing.',
    id: 'descriptionField',
    name: 'descriptionField',
    value: settings.descriptionField,
    placeholder: 'e.g., summary or seo.seoDescription',
    size: 40,
}) }}

<hr>

<h2>Front Matter</h2>

<p class="light">Overrides for the YAML front matter that appears at the top of each Markdown response.</p>

{{ forms.textField({
    label: 'Title Field',
    instructions: 'Optional field handle used for the front-matter <code>title:</code> value. Supports the same syntax as Description Field (dot notation, <code>()</code> method calls, Generated Field handles, and <code>seomatic:title</code>). Leave blank to use the entry\'s native title. If set but the field resolves to an empty value, falls back to the entry\'s native title — every Markdown response always has a title.',
    id: 'titleField',
    name: 'titleField',
    value: settings.titleField,
    placeholder: 'e.g., longTitle or seomatic:title',
    size: 40,
}) }}

{{ forms.textField({
    label: 'Author Override',
    instructions: 'Optional fixed author name written to every entry\'s front matter. Useful when you want a single authoritative byline (e.g., an editorial team name) instead of leaking individual editor names. Leave blank to use each entry\'s own author.',
    id: 'authorOverride',
    name: 'authorOverride',
    value: settings.authorOverride,
    placeholder: 'e.g., Acme Editorial Team',
    size: 40,
}) }}

<hr>

<h2>Analytics</h2>

{{ forms.lightswitchField({
    label: 'Enable Analytics',
    instructions: 'Log requests to <code>.md</code> pages, <code>/llms.txt</code>, and content negotiation responses for the analytics dashboard.',
    id: 'enableAnalytics',
    name: 'enableAnalytics',
    on: settings.enableAnalytics,
}) }}

{{ forms.textField({
    label: 'Data Retention (days)',
    instructions: 'How many days of analytics data to keep. Older data can be purged via the dashboard or the <code>llm-ready/analytics/purge</code> console command.',
    id: 'analyticsRetentionDays',
    name: 'analyticsRetentionDays',
    value: settings.analyticsRetentionDays,
    type: 'number',
    min: 1,
    size: 10,
}) }}

<hr>

<h2>Section Settings</h2>
<p class="light">Configure which sections serve Markdown output and optionally assign dedicated LLM templates.</p>

{% for sectionInfo in sectionData %}
    <h3 style="margin-top: 24px;">{{ sectionInfo.section.name }} <span class="light">({{ sectionInfo.section.type }})</span></h3>

    <table class="data fullwidth">
        <thead>
            <tr>
                <th>Site</th>
                <th>Enabled</th>
                <th>LLM Template</th>
            </tr>
        </thead>
        <tbody>
            {% for siteInfo in sectionInfo.sites %}
                <tr>
                    <td>{{ siteInfo.site.name }}</td>
                    <td>
                        {% set toggleName = 'sectionSettings[' ~ sectionInfo.section.id ~ '][' ~ siteInfo.site.id ~ '][enabled]' %}
                        <div>
                            {{ forms.lightswitch({
                                name: toggleName,
                                on: siteInfo.enabled,
                                small: true,
                            }) }}
                        </div>
                    </td>
                    <td>
                        {% set templateName = 'sectionSettings[' ~ sectionInfo.section.id ~ '][' ~ siteInfo.site.id ~ '][llmTemplate]' %}
                        {{ forms.text({
                            name: templateName,
                            value: siteInfo.llmTemplate,
                            placeholder: 'e.g., _llm/blog',
                            size: 40,
                        }) }}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endfor %}

{% if sectionData is empty %}
    <p class="zilch">No sections with URLs found.</p>
{% endif %}
